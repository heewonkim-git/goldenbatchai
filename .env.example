# --- Anthropic (MSAT Agent) ---
ANTHROPIC_API_KEY=sk-ant-...
MSAT_MODEL=claude-opus-4-8

# --- Runtime ---
# SEED_MODE=1 uses the bundled demo dataset + cached scenario for stable demos.
SEED_MODE=1
# AutoML/SHAP time budget in seconds (live mode). Seed mode uses precomputed cache.
TIME_BUDGET_S=120
# Default AutoML framework: autogluon | h2o
AUTOML_FRAMEWORK=autogluon

# --- Server ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# Comma-separated origins allowed to call the backend (the Next.js dev server).
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
# Base URL the browser uses to reach the FastAPI backend.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
