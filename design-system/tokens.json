{
  "version": "1.1.0",
  "description": "Machine-readable mirror of tokens.css (Samsung Blue palette). Light values are canonical; dark overrides live in tokens.css.",
  "prefix": "--ds-",
  "color": {
    "brand": { "DEFAULT": "#1428a0", "hover": "#0f1f80", "active": "#0a1660", "fg": "#ffffff", "subtle": "#eaeefb" },
    "bg": "#fbfcfe",
    "surface": { "DEFAULT": "#ffffff", "2": "#f2f5fa" },
    "border": { "DEFAULT": "#e4e8f0", "strong": "#c9d0de" },
    "text": { "DEFAULT": "#0c1017", "muted": "#4c5568", "subtle": "#8a93a5" },
    "success": { "DEFAULT": "#16a34a", "bg": "#f0fdf4" },
    "warning": { "DEFAULT": "#d97706", "bg": "#fffbeb" },
    "danger": { "DEFAULT": "#dc2626", "bg": "#fef2f2" },
    "info": { "DEFAULT": "#2a5bd7", "bg": "#eaf0fc" },
    "accent1": { "DEFAULT": "#1428a0", "bg": "rgba(20,40,160,0.06)" },
    "accent2": { "DEFAULT": "#7c3aed", "bg": "rgba(124,58,237,0.06)" },
    "accent3": { "DEFAULT": "#0d9488", "bg": "rgba(13,148,136,0.06)" },
    "accent4": { "DEFAULT": "#d97706", "bg": "rgba(217,119,6,0.06)" }
  },
  "font": {
    "sans": "ui-sans-serif, system-ui, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "serif": "ui-serif, Georgia, 'Iowan Old Style', 'Times New Roman', serif",
    "mono": "ui-monospace, 'Cascadia Code', 'SF Mono', Consolas, monospace"
  },
  "fontSize": {
    "xs": "0.75rem", "sm": "0.8125rem", "base": "0.875rem",
    "md": "0.9375rem", "lg": "1.125rem", "xl": "1.375rem", "2xl": "1.75rem"
  },
  "fontWeight": { "normal": 400, "medium": 500, "semibold": 600, "bold": 700 },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "full": "9999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(12,16,23,0.06)",
    "md": "0 4px 12px rgba(12,16,23,0.08)",
    "lg": "0 10px 30px rgba(12,16,23,0.12)"
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "6": "24px", "8": "32px" },
  "layout": { "appbarHeight": "52px", "contentMax": "1440px" },
  "motion": { "transition": "150ms ease" },
  "roleMapping": {
    "golden-batch": { "accent1": "Analysis Agent", "accent2": "MSAT Agent" },
    "deviation-review": { "accent1": "TBD", "accent2": "TBD", "note": "map deviation entities (e.g. severity, status) onto accent/status slots" }
  }
}
